# =====================================================
# celx-atendimento - Development Environment
# =====================================================

# Database
DATABASE_URL=postgresql+asyncpg://postgres:celx123456@localhost:5432/celx_atendimento
SYNC_DATABASE_URL=postgresql://postgres:celx123456@localhost:5432/celx_atendimento

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=dev-secret-key-1234567890abcdefghijk
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Encryption (32 bytes)
ENCRYPTION_KEY=dev-encryption-key-32-bytes-ok

# OpenRouter (URL padrão)
OPENROUTER_API_URL=https://openrouter.ai/api/v1

# Langfuse (Opcional)
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=http://localhost:3001

# Frontend URL
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
