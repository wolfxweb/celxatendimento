# =====================================================
# celx-atendimento - Environment Variables
# =====================================================

# Database
DATABASE_URL=postgresql+asyncpg://postgres:celx123456@postgres:5432/celx_atendimento
SYNC_DATABASE_URL=postgresql://postgres:celx123456@postgres:5432/celx_atendimento

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
SECRET_KEY=sua-chave-secreta-muito-longa-aqui-123456789abcdefghijk
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Encryption (32 bytes para Fernet - AES-256)
# IMPORTANTE: Altere esta chave em produção!
ENCRYPTION_KEY=sua-chave-32-bytes-aqui12345

# OpenRouter (URL padrão - cada cliente tem sua própria chave no banco)
OPENROUTER_API_URL=https://openrouter.ai/api/v1

# Langfuse (Opcional - para observabilidade)
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=http://langfuse:3000

# Frontend URL
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
