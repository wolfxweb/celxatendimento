# =====================================================
# celx-atendimento - Environment Variables Example
# =====================================================
# Copie este arquivo para .env e ajuste os valores

# =====================================================
# PORTAS (opcional - padrões mostrados)
# =====================================================
# FRONTEND_PORT=3000
# BACKEND_PORT=8000
# POSTGRES_PORT=5432
# REDIS_PORT=6379
# PGADMIN_PORT=5050

# =====================================================
# POSTGRESQL
# =====================================================
POSTGRES_PASSWORD=celx123456

# =====================================================
# PGADMIN
# =====================================================
PGADMIN_EMAIL=admin@celx.com.br
PGADMIN_PASSWORD=celx123456

# =====================================================
# JWT / SECURITY
# =====================================================
SECRET_KEY=sua-chave-secreta-muito-longa-aqui-123456789abcdefghijk-que-eh-segura
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Encryption key (32 bytes para Fernet - AES-256)
# ⚠️ IMPORTANTE: Altere para uma chave única em produção!
ENCRYPTION_KEY=sua-chave-32-bytes-aqui12345

# =====================================================
# OPENROUTER (API IA)
# =====================================================
OPENROUTER_API_URL=https://openrouter.ai/api/v1
# OPENROUTER_API_KEY=sua-chave-aqui (cada empresa configura a sua no banco)

# =====================================================
# LANGFUSE (Opcional - observabilidade)
# =====================================================
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=http://langfuse:3000