# =========================
# Sistema Celx-Atendimento
# =========================

# --- Python / Backend ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
# lib/
# lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg
venv/
.venv/

# --- Variáveis de Ambiente (Segurança) ---
# Ignorar arquivos .env em qualquer pasta (backend, frontend, raiz)
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local
*.env

# Não ignorar os arquivos de exemplo! (Eles devem ir para o github)
!**/.env.example
!**/.env.sample

# Caches de Lint e Testes
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# --- Node / Frontend (Next.js) ---
node_modules/
npm-debug.log
yarn-error.log
yarn-debug.log
.pnpm-debug.log
.next/
out/
build/
dist/
.eslintcache

# --- OS e IDEs ---
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# =========================
# EXCEÇÕES (NÃO IGNORAR)
# =========================
# Garantimos que a pasta de inteligência do Kilo Code será comitada!
# (Nota: A própria pasta .kilo já tem um .gitignore interno para ignorar o node_modules dela)
!.kilo/
